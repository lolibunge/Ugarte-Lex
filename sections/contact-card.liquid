{% comment %}
  Section: Contact card (image + content)
  Blocks: image, heading, text, button
{% endcomment %}

{%- liquid
  assign image_block = nil

  for block in section.blocks
    if block.type == 'image'
      assign image_block = block
      break
    endif
  endfor
-%}

<section class="contact-card" aria-label="{{ section.settings.aria_label | escape }}">
  <div class="contact-card__inner">
    <div class="contact-card__media" {% if image_block == nil %}hidden{% endif %}>
      {%- if image_block != nil -%}
        {%- liquid
          assign img = image_block.settings.image
          assign alt = image_block.settings.alt | default: img.alt
        -%}

        {%- if img != blank -%}
          {{
            img
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              widths: '320, 480, 640, 800, 1000, 1200',
              sizes: '(min-width: 990px) 360px, 100vw',
              alt: alt
          }}
        {%- endif -%}
      {%- endif -%}
    </div>

    <div class="contact-card__content">
      {%- for block in section.blocks -%}
        {%- if block.type != 'image' -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              {%- if block.settings.title != blank -%}
                <h2 class="contact-card__title" {{ block.shopify_attributes }}>
                  {{ block.settings.title }}
                </h2>
              {%- endif -%}

            {%- when 'text' -%}
              {%- if block.settings.text != blank -%}
                <div class="contact-card__text rte" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </div>
              {%- endif -%}

            {%- when 'button' -%}
              {%- if block.settings.label != blank and block.settings.link != blank -%}
                <div class="contact-card__actions" {{ block.shopify_attributes }}>
                  <a
                    class="{{ block.settings.button_class }}"
                    href="{{ block.settings.link }}"
                    {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                  >
                    {{ block.settings.label }}
                  </a>
                </div>
              {%- endif -%}
          {%- endcase -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .contact-card__inner {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .contact-card__media {
    flex: 0 0 220px;
    max-width: 220px;
  }

  .contact-card__media img {
    display: block;
    width: 100%;
    height: auto;
  }

  .contact-card__content {
    flex: 1 1 auto;
    min-width: 0;
    text-align: center;
  }

  @media (max-width: 749px) {
    .contact-card__inner {
      flex-direction: column;
      align-items: stretch;
    }

    .contact-card__media {
      max-width: 100%;
      flex-basis: auto;
    }
  }
</style>

{% schema %}
{
  "name": "Contact card",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Contact card"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text (optional)" }
      ]
    },
    {
      "type": "heading",
      "name": "Title",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Cerrito 1266, Piso 6, Of. 25, CABA." }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add your description here.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Contact" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select",
          "id": "button_class",
          "label": "Button class",
          "default": "button button--primary",
          "options": [
            { "value": "button button--primary", "label": "Primary" },
            { "value": "button button--secondary", "label": "Secondary" },
            { "value": "button", "label": "Default" }
          ]
        },
        { "type": "checkbox", "id": "open_new_tab", "label": "Open in new tab", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact card",
      "blocks": [
        { "type": "image" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}